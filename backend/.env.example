# MongoDB Atlas connection string (replace with your cluster connection)
MONGODB_URI=mongodb+srv://<user>:<pass>@cluster0.mongodb.net/leads?retryWrites=true&w=majority
PORT=4000
BACKEND_URL=https://<your-backend>.onrender.com
FRONTEND_URL=https://<your-frontend>.vercel.app

# SMTP settings (for production use your SMTP provider credentials)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-pass
SMTP_FROM=no-reply@yourdomain.com
